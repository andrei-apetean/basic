{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "clang",
            "args": [
                "-g",
                "-Wall",
                "-Wextra",
                "-Werror",
                "-Iinclude",
                "-o", "bin/main.exe",
                "src/main.c"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "run",
            "type": "shell",
            "command": "bin/main.exe",
            "dependsOn": "build",
            "group": "test"
        }
    ]
}